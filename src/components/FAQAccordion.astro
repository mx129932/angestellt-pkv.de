---
/**
 * FAQAccordion.astro — CSS-only Akkordeon für FAQ-Blöcke.
 * Setzt Schema.org FAQPage-JSON-LD.
 */
export interface Item {
  q: string;
  a: string;
}

export interface Props {
  heading?: string;
  intro?: string;
  items: Item[];
  /** IDs müssen pro Seite eindeutig sein → Prefix vergeben */
  idPrefix?: string;
}

const { heading = 'Häufige Fragen', intro, items, idPrefix = 'faq' } = Astro.props;

// JSON-LD wird zentral in Base.astro via @graph ausgegeben.
// FAQ-Daten muessen als faqItems-Prop an das Layout uebergeben werden.
---

<section class='py-16 bg-surface-container-lowest'>
  <div class='max-w-4xl mx-auto px-6 md:px-8'>
    <h2 class='text-3xl md:text-4xl font-serif text-primary mb-4'>{heading}</h2>
    {intro && <p class='text-on-surface-variant mb-10 max-w-2xl'>{intro}</p>}

    <div class='space-y-3'>
      {items.map((it, i) => {
        const id = `${idPrefix}-${i}`;
        return (
          <div class='bg-surface-container-low rounded-md overflow-hidden'>
            <input type='checkbox' id={id} class='hidden peer' />
            <label
              for={id}
              class='flex justify-between items-center gap-4 cursor-pointer p-5 md:p-6 hover:bg-surface-container transition-colors'
            >
              <h3 class='text-base md:text-lg font-serif text-primary pr-4'>{it.q}</h3>
              <span class='material-symbols-outlined text-primary transition-transform duration-200 peer-checked:rotate-45 shrink-0'>add</span>
            </label>
            <div class='grid grid-rows-[0fr] peer-checked:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out'>
              <div class='overflow-hidden'>
                <p class='px-5 md:px-6 pb-5 md:pb-6 text-on-surface-variant text-sm md:text-base leading-relaxed'>{it.a}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>


</section>

<style>
  /* Chevron-Rotation an Checkbox koppeln */
  input[type='checkbox']:checked + label .material-symbols-outlined {
    transform: rotate(45deg);
  }
  /* Inhalt aufklappen */
  input[type='checkbox']:checked ~ div {
    grid-template-rows: 1fr;
  }
</style>
