---
/**
 * ContactOverlay — Modal mit Kontaktoptionen.
 * Analog zu selbststaendig-pkv.de "kostenlose Beratung anfragen".
 * Wird per JS über data-contact-trigger Buttons geöffnet.
 */
---
<!-- Contact Overlay -->
<div
  id="contact-overlay"
  class="fixed inset-0 z-[9999] hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Kontakt aufnehmen"
>
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" data-contact-close></div>

  <!-- Panel -->
  <div class="absolute inset-0 flex items-center justify-center p-4">
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md overflow-hidden">
      <!-- Header -->
      <div class="bg-primary px-6 py-5 text-white">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="font-serif text-xl font-semibold">Kontakt aufnehmen</h2>
            <p class="text-white/70 text-sm mt-1">Wähle deinen bevorzugten Weg</p>
          </div>
          <button
            class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-white/10 transition-colors"
            data-contact-close
            aria-label="Schließen"
          >
            <span class="material-symbols-outlined text-2xl">close</span>
          </button>
        </div>
      </div>

      <!-- Options -->
      <div class="p-4 space-y-2">
        <!-- Telefon -->
        <a
          href="tel:+4952197798232"
          class="flex items-center gap-4 px-4 py-4 rounded-xl hover:bg-[#FAF7F2] transition-colors group"
        >
          <span class="w-11 h-11 flex items-center justify-center rounded-full bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-xl">phone</span>
          </span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-primary text-sm">Anrufen</p>
            <p class="text-xs text-on-surface-variant">+49 521 97 79 82 32</p>
          </div>
          <span class="material-symbols-outlined text-on-surface-variant/40 text-lg group-hover:text-primary transition-colors">arrow_forward</span>
        </a>

        <!-- WhatsApp -->
        <a
          href="https://wa.me/491797998239?text=Hallo%2C%20ich%20interessiere%20mich%20f%C3%BCr%20eine%20PKV-Beratung%20f%C3%BCr%20Angestellte."
          target="_blank"
          rel="noopener"
          class="flex items-center gap-4 px-4 py-4 rounded-xl hover:bg-[#FAF7F2] transition-colors group"
        >
          <span class="w-11 h-11 flex items-center justify-center rounded-full bg-[#25D366]/10 text-[#25D366] group-hover:bg-[#25D366] group-hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-primary text-sm">WhatsApp</p>
            <p class="text-xs text-on-surface-variant">Direkt per Chat schreiben</p>
          </div>
          <span class="material-symbols-outlined text-on-surface-variant/40 text-lg group-hover:text-primary transition-colors">arrow_forward</span>
        </a>

        <!-- E-Mail -->
        <a
          href="mailto:beratung@angestellt-pkv.de?subject=PKV-Beratung%20f%C3%BCr%20Angestellte"
          class="flex items-center gap-4 px-4 py-4 rounded-xl hover:bg-[#FAF7F2] transition-colors group"
        >
          <span class="w-11 h-11 flex items-center justify-center rounded-full bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-xl">mail</span>
          </span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-primary text-sm">E-Mail schreiben</p>
            <p class="text-xs text-on-surface-variant">beratung@angestellt-pkv.de</p>
          </div>
          <span class="material-symbols-outlined text-on-surface-variant/40 text-lg group-hover:text-primary transition-colors">arrow_forward</span>
        </a>

        <!-- Rückruf / Beratungsseite -->
        <a
          href="/beratung/"
          class="flex items-center gap-4 px-4 py-4 rounded-xl hover:bg-[#FAF7F2] transition-colors group"
        >
          <span class="w-11 h-11 flex items-center justify-center rounded-full bg-amber-accent/10 text-amber-accent-dark group-hover:bg-amber-accent group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-xl">calendar_month</span>
          </span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-primary text-sm">Beratungstermin</p>
            <p class="text-xs text-on-surface-variant">Kostenfrei und unverbindlich</p>
          </div>
          <span class="material-symbols-outlined text-on-surface-variant/40 text-lg group-hover:text-primary transition-colors">arrow_forward</span>
        </a>
      </div>

      <!-- Footer -->
      <div class="px-6 py-3 bg-[#FAF7F2] border-t border-outline-variant/20 text-center">
        <p class="text-[11px] text-on-surface-variant flex items-center justify-center gap-1.5">
          <span class="material-symbols-outlined text-[14px]">verified_user</span>
          Alle Beratungen sind kostenlos und unverbindlich.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  // Contact Overlay Controller
  (function() {
    const overlay = document.getElementById('contact-overlay');
    if (!overlay) return;

    function open() {
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }

    // Open triggers: any element with data-contact-trigger
    document.querySelectorAll('[data-contact-trigger]').forEach(el => {
      el.addEventListener('click', (e) => { e.preventDefault(); open(); });
    });

    // Close triggers
    overlay.querySelectorAll('[data-contact-close]').forEach(el => {
      el.addEventListener('click', close);
    });

    // Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.classList.contains('hidden')) close();
    });
  })();
</script>
