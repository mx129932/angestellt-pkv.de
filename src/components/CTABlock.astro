---
/**
 * CTABlock.astro — Full-width Beratungs-/Rechner-CTA. Navy-Grund, Amber-Button.
 * Zwei Varianten: "beratung" (Standard) oder "rechner" (verlinkt auf /rechner/).
 */
export interface Props {
  variant?: 'beratung' | 'rechner';
  headline?: string;
  subline?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  variant = 'beratung',
  headline = variant === 'rechner'
    ? 'In 60 Sekunden: Was kostet die PKV wirklich?'
    : 'Unsicher, ob die PKV für dich Sinn macht?',
  subline = variant === 'rechner'
    ? 'Präzises Modell mit aktuellen Zahlen 2026. Ohne Anmeldung.'
    : 'Unverbindliches Gespräch mit unabhängigem Experten. Kein Verkauf, keine Versicherungsbindung.',
  ctaLabel = variant === 'rechner' ? 'Jetzt berechnen' : 'Beratung vereinbaren',
  ctaHref = variant === 'rechner' ? '/rechner/' : '/beratung/',
} = Astro.props;
---

<section class='relative bg-primary text-white overflow-hidden py-20 md:py-24'>
  <div class='max-w-5xl mx-auto px-6 md:px-8 relative z-10 text-center'>
    <h2 class='text-3xl md:text-5xl font-serif leading-tight mb-5'>{headline}</h2>
    <p class='text-primary-fixed-dim text-lg md:text-xl mb-10 max-w-2xl mx-auto'>{subline}</p>
    {variant === 'beratung' ? (
      <button
        data-contact-trigger
        class='inline-flex items-center gap-2 bg-amber-accent hover:bg-amber-accent-dark text-white font-bold px-8 md:px-10 py-4 md:py-5 rounded-md transition-all shadow-xl shadow-black/20 active:scale-95 cursor-pointer'
      >
        Experte kontaktieren
        <span class='material-symbols-outlined'>support_agent</span>
      </button>
    ) : (
      <a
        href={ctaHref}
        class='inline-flex items-center gap-2 bg-amber-accent hover:bg-amber-accent-dark text-white font-bold px-8 md:px-10 py-4 md:py-5 rounded-md transition-all shadow-xl shadow-black/20 active:scale-95'
      >
        {ctaLabel}
        <span class='material-symbols-outlined'>arrow_forward</span>
      </a>
    )}
  </div>
  <!-- dekorativer Blur-Kreis -->
  <div class='absolute -right-24 -bottom-24 w-96 h-96 bg-tertiary-container/20 rounded-full blur-[100px] pointer-events-none'></div>
  <div class='absolute -left-24 -top-24 w-72 h-72 bg-amber-accent/10 rounded-full blur-[100px] pointer-events-none'></div>
</section>
