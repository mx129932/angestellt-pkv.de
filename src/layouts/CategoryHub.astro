---
/**
 * CategoryHub.astro — Layout für Kategorie-Übersichtsseiten (/grundlagen/, /kosten/ etc.)
 *
 * Ersetzt T3 (Stitch-Export). Schlankes Layout:
 *   Breadcrumbs → H1 + Meta in Sidebar → Intro → "Mehr zu …" Artikelgrid
 *   → CTA → FAQ.
 *
 * Artikelgrid liest Kinder aus src/data/ia.json.
 */
import Base from './Base.astro';
import ia from '../data/ia.json';
import altTexts from '../data/image-alt-texts.json';

export interface FaqItem { q: string; a: string; }

export interface RechnerTeaser { href: string; title: string; icon?: string; }

export interface Props {
  /** Slug der Kategorie, z. B. 'grundlagen' */
  kategorieSlug: string;
  /** Fallback-Titel (sonst aus ia.json Ebene-1) */
  title?: string;
  description?: string;
  /** Keyword hinter "Mehr zu …" — sonst wird Kategorie-Titel verwendet */
  keyword?: string;
  /** Einleitungs-Text (2–3 Sätze) */
  intro?: string;
  /** FAQ-Liste (CSS-only Akkordeon, standardmäßig zugeklappt) */
  faq?: FaqItem[];
  /** 3 "beliebte Rechner" für die Sidebar */
  popularRechner?: RechnerTeaser[];
}

const defaultPopularRechner: RechnerTeaser[] = [
  { href: '/rechner/pkv-beitrag/', title: 'PKV-Beitragsrechner', icon: 'calculate' },
  { href: '/rechner/pkv-gkv-vergleich/', title: 'GKV vs. PKV Vergleich', icon: 'compare_arrows' },
  { href: '/rechner/arbeitgeberzuschuss/', title: 'Arbeitgeberzuschuss', icon: 'business_center' },
];

const {
  kategorieSlug,
  title,
  description,
  keyword,
  intro,
  faq = [],
  popularRechner = defaultPopularRechner,
} = Astro.props;

// Kategorie-Hub aus ia.json
const hub = (ia as any[]).find((x) => x.ebene === 1 && x.kategorie === kategorieSlug);
const pageTitle = title ?? hub?.title ?? kategorieSlug;
const pageDescription = description ?? hub?.bemerkung ?? undefined;
const hubUrl = hub?.url ?? `/${kategorieSlug}/`;
const heroKeyword = keyword ?? hub?.title ?? kategorieSlug;

// Kinder: alle Seiten unterhalb des Kategorie-Slugs, ebene >= 2
const children = (ia as any[])
  .filter((x) => x.kategorie === kategorieSlug && x.ebene >= 2)
  .map((x) => x);

// Vorschau-Icon-Mapping pro Artikel (bis wir echte Bilder haben)
const iconFor: Record<string, string> = {
  'gkv-vs-pkv': 'compare_arrows',
  'lohnt-sich-pkv': 'trending_up',
  'vor-und-nachteile': 'balance',
  versicherungspflichtgrenze: 'gavel',
  'gkv-in-pkv': 'login',
  'pkv-in-gkv': 'logout',
  'tarifwechsel-204': 'sync_alt',
  optionstarif: 'bookmark_add',
  'pkv-kosten-uebersicht': 'payments',
  arbeitgeberzuschuss: 'business_center',
  beitragsanpassung: 'trending_up',
  selbstbeteiligung: 'percent',
  'pkv-steuer': 'receipt_long',
  altersrueckstellung: 'savings',
  'gkv-hoechstbeitrag': 'euro_symbol',
  'gkv-zusatzbeitrag': 'add_circle',
  'pkv-im-alter': 'elderly',
  uebersicht: 'view_list',
  tarifbausteine: 'dashboard',
  'beste-pkv': 'star',
  'basistarif-standardtarif': 'shield',
  gesundheitspruefung: 'medical_information',
  risikovoranfrage: 'help',
  risikozuschlag: 'warning',
  leistungsausschluesse: 'block',
  wartezeiten: 'schedule',
  krankentagegeld: 'event_busy',
  berufsunfaehigkeit: 'accessibility_new',
  mutterschutz: 'pregnant_woman',
  kinder: 'child_care',
  elternzeit: 'stroller',
  rente: 'beach_access',
  'kuendigung-jobwechsel': 'work',
  'angestellt-selbststaendig': 'groups',
  'oeffentlicher-dienst': 'account_balance',
  bkv: 'business',
};

// Hero-Bild Auto-Erkennung fuer Hub-Seiten
const heroId = `hero-hub-${kategorieSlug}`;
const heroData = (altTexts as Record<string, { alt: string; size: string }>)[heroId];
const heroSrc = heroData ? `/img/${heroId}.webp` : '';
const heroAlt = heroData?.alt || '';

function slugFromUrl(url: string) {
  const parts = url.replace(/\/$/, '').split('/').filter(Boolean);
  return parts[parts.length - 1] ?? '';
}
---
<Base
  title={`${pageTitle} | PKV für Angestellte`}
  description={pageDescription}
  schemaType='CollectionPage'
  breadcrumbs={[
    { label: 'Start', href: '/' },
    { label: pageTitle, href: '' }
  ]}
  faqItems={faq.length > 0 ? faq.map(f => ({ question: f.q, answer: f.a })) : undefined}
  schemaExtra={children.length > 0 ? [{
    "@type": "ItemList",
    "@id": `${new URL(hubUrl, Astro.site ?? 'https://angestellt-pkv.de').href}#itemlist`,
    "itemListElement": children.map((c: any, i: number) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": new URL(c.url, Astro.site ?? 'https://angestellt-pkv.de').href
    }))
  }] : []}
>
  <main class='bg-[#FAF7F2]'>
    <!-- Breadcrumbs — minimaler Top-Abstand (Mobile nicht zu luftig) -->
    <nav class='max-w-6xl mx-auto pt-6 md:pt-10 px-6 md:px-8 flex items-center gap-2 text-xs uppercase tracking-widest text-on-surface-variant' aria-label='Breadcrumb'>
      <a class='hover:text-primary transition-colors' href='/'>Home</a>
      <span class='material-symbols-outlined text-[14px]'>chevron_right</span>
      <span class='text-primary font-semibold'>{pageTitle}</span>
    </nav>

    <div class='max-w-6xl mx-auto px-6 md:px-8 py-8 md:py-12 grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16'>

      <!-- SIDEBAR: Beliebte Rechner + About-Teaser
           Mobile: Headlines wie "Häufige Fragen" (font-serif text-2xl), damit Blöcke
           als eigenständige Content-Sections lesbar sind.
           Desktop: Micro-Label über "Beliebte Rechner" (bestand), plus zusätzlich
           über dem About-Teaser. -->
      <aside class='lg:col-span-3 order-2 lg:order-1 space-y-12 lg:space-y-0'>
        <div class='lg:sticky lg:top-28 space-y-12 lg:space-y-8'>
          {popularRechner.length > 0 && (
            <section>
              <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6 md:mb-8 lg:text-[10px] lg:font-bold lg:uppercase lg:tracking-[0.2em] lg:text-on-surface-variant lg:font-body lg:mb-4'>Beliebte Rechner</h2>
              <ul class='space-y-2'>
                {popularRechner.map((r) => (
                  <li>
                    <a
                      href={r.href}
                      class='flex items-center gap-3 p-3 bg-white border border-outline-variant/20 rounded-md hover:border-amber-accent/60 hover:shadow-sm transition-all group'
                    >
                      <span class='shrink-0 w-9 h-9 rounded-md bg-gradient-to-br from-[#FAF7F2] to-amber-accent/10 border border-outline-variant/20 flex items-center justify-center'>
                        <span class='material-symbols-outlined text-amber-accent-dark text-[18px]' aria-hidden='true'>{r.icon ?? 'calculate'}</span>
                      </span>
                      <span class='text-sm font-medium text-primary leading-snug group-hover:text-amber-accent-dark transition-colors'>{r.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <section>
            <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6 md:mb-8 lg:text-[10px] lg:font-bold lg:uppercase lg:tracking-[0.2em] lg:text-on-surface-variant lg:font-body lg:mb-4'>Über uns</h2>
            <a href='/ueber-uns/' class='block bg-white border border-outline-variant/20 rounded-lg overflow-hidden hover:border-amber-accent/60 hover:shadow-md hover:shadow-primary/5 transition-all group'>
              <div class='aspect-[4/3] bg-gradient-to-br from-[#FAF7F2] to-amber-accent/10 overflow-hidden'>
                <picture>
                  <source srcset='/images/tim-experte.webp' type='image/webp' />
                  <img
                    src='/images/tim-experte.png'
                    alt='Tim Bökemeier, PKV-Experte für Angestellte'
                    loading='lazy'
                    class='w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500'
                  />
                </picture>
              </div>
              <div class='p-4'>
                <p class='font-serif text-base text-primary leading-tight mb-3'>Tim Bökemeier und das PKV-Welt Team</p>
                <span class='inline-flex items-center gap-1 text-primary font-semibold text-xs group-hover:gap-2 transition-all'>
                  Mehr über uns erfahren
                  <span class='material-symbols-outlined text-[14px]'>arrow_forward</span>
                </span>
              </div>
            </a>
          </section>
        </div>
      </aside>

      <!-- MAIN -->
      <article class='lg:col-span-9 order-1 lg:order-2 min-w-0'>
        <!-- H1 + Hero-Bild -->
        <header id='einstieg' class='mb-10 md:mb-14'>
          <div class={`grid grid-cols-1 ${heroSrc ? 'lg:grid-cols-12' : ''} gap-8 lg:gap-12 items-start`}>
            <div class={heroSrc ? 'lg:col-span-8' : ''}>
              <h1 class='font-serif text-primary font-semibold leading-[1.1] break-words text-3xl sm:text-4xl md:text-5xl lg:text-6xl'>
                {pageTitle}
              </h1>
            </div>
            {heroSrc && (
              <div class='lg:col-span-4 min-w-0'>
                <div class='relative aspect-[3/2] w-full rounded-xl overflow-hidden shadow-lg shadow-primary/10'>
                  <img alt={heroAlt} class='w-full h-full object-cover' src={heroSrc} loading='eager' />
                </div>
              </div>
            )}
          </div>
        </header>

        {intro && (
          <section class='max-w-[680px] mb-14 md:mb-16 text-base md:text-lg leading-relaxed text-on-surface/90'>
            <p>{intro}</p>
          </section>
        )}

        <!-- "Mehr zu …" Artikelgrid -->
        <section id='artikel' class='mb-16 md:mb-20'>
          <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6 md:mb-8'>
            Mehr zu {heroKeyword}
          </h2>

          {children.length === 0 ? (
            <p class='text-on-surface-variant italic'>In dieser Kategorie sind noch keine Beiträge erfasst.</p>
          ) : (
            <ul class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4 items-stretch auto-rows-fr'>
              {children.map((c) => {
                const slug = slugFromUrl(c.url);
                const icon = iconFor[slug] ?? 'article';
                return (
                  <li class='h-full'>
                    <a
                      href={c.url}
                      class='h-full min-h-[92px] flex items-center gap-4 bg-white border border-outline-variant/20 rounded-lg p-4 hover:border-amber-accent/60 hover:shadow-md hover:shadow-primary/5 transition-all group'
                    >
                      <!-- kleines Vorschaubild-Quadrat, kein Crop — volles Icon zentriert -->
                      <span class='shrink-0 w-14 h-14 rounded-md bg-gradient-to-br from-[#FAF7F2] to-amber-accent/10 border border-outline-variant/20 flex items-center justify-center'>
                        <span class='material-symbols-outlined text-amber-accent-dark text-[26px]' aria-hidden='true'>{icon}</span>
                      </span>
                      <h3 class='font-serif text-base md:text-lg text-primary leading-snug group-hover:text-amber-accent-dark transition-colors break-words min-w-0 flex-1'>
                        {c.title}
                      </h3>
                    </a>
                  </li>
                );
              })}
            </ul>
          )}
        </section>

        <!-- CTA -->
        <section id='beratung' class='mb-16 md:mb-20'>
          <div class='relative overflow-hidden bg-primary text-white rounded-2xl p-8 md:p-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6'>
            <div class='relative z-10 max-w-xl'>
              <h3 class='font-serif text-2xl md:text-3xl leading-tight mb-3'>
                Unsicher, ob die PKV für dich passt?
              </h3>
              <p class='text-primary-fixed-dim text-sm md:text-base'>
                Unverbindliches Gespräch mit unabhängigem Experten. Kein Verkauf, keine Provision.
              </p>
            </div>
            <a
              href='/beratung/'
              class='relative z-10 inline-flex items-center gap-2 bg-amber-accent hover:bg-amber-accent-dark text-white font-semibold px-6 py-3 rounded-md transition-all shrink-0'
            >
              Beratung vereinbaren
              <span class='material-symbols-outlined text-[18px]'>arrow_forward</span>
            </a>
            <div class='absolute -right-20 -bottom-20 w-72 h-72 bg-tertiary-container/20 rounded-full blur-[100px] pointer-events-none'></div>
          </div>
        </section>

        <!-- FAQ — zugeklappt, CSS-only -->
        {faq.length > 0 && (
          <section id='faq' class='mb-12'>
            <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6 md:mb-8'>Häufige Fragen</h2>
            <div class='space-y-3'>
              {faq.map((it, i) => {
                const id = `${kategorieSlug}-faq-${i}`;
                return (
                  <div class='bg-white border border-outline-variant/20 rounded-md overflow-hidden'>
                    <input type='checkbox' id={id} class='hidden peer' />
                    <label
                      for={id}
                      class='flex justify-between items-center gap-4 cursor-pointer p-5 hover:bg-surface-container-low transition-colors'
                    >
                      <h3 class='font-serif text-base md:text-lg text-primary pr-4'>{it.q}</h3>
                      <span class='material-symbols-outlined text-primary transition-transform duration-200 peer-checked:rotate-45 shrink-0'>add</span>
                    </label>
                    <div class='grid grid-rows-[0fr] peer-checked:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out'>
                      <div class='overflow-hidden'>
                        <p class='px-5 pb-5 text-on-surface-variant text-sm md:text-base leading-relaxed'>{it.a}</p>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </section>
        )}

        <slot />
      </article>
    </div>
  </main>
</Base>
