<aside class="hidden md:block md:col-span-3">
<div class="sticky top-40 space-y-4">
<nav class="flex flex-col border-l border-outline-variant/30 pl-6 space-y-4">
<a class="text-sm font-medium text-primary border-l-2 border-primary -ml-[26px] pl-6 py-1" href="#general">General Information</a>
<a class="text-sm text-on-surface-variant hover:text-primary transition-colors py-1" href="#collection">Data Collection</a>
<a class="text-sm text-on-surface-variant hover:text-primary transition-colors py-1" href="#rights">Your Rights</a>
<a class="text-sm text-on-surface-variant hover:text-primary transition-colors py-1" href="#tracking">Tracking &amp; Cookies</a>
<a class="text-sm text-on-surface-variant hover:text-primary transition-colors py-1" href="#contact">Privacy Contact</a>
</nav>
</div>
</aside>
<!-- Editorial Policy Content -->
<div class="md:col-span-8 md:col-start-5 space-y-16">
