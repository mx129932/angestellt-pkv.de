<span class="material-symbols-outlined text-xs">mail</span>
                                        privacy@financial-architect.de
                                    </p>
</div>
</div>
</div>
<!-- Decorative background element -->
<div class="absolute -right-20 -bottom-20 w-64 h-64 bg-primary-container rounded-full opacity-50 blur-3xl"></div>
</div>
</section>
</div>
</div>
