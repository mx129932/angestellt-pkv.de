            </div>
<nav class="hidden md:flex items-center space-x-8">
<a class="text-[#44474e] hover:text-[#002046] transition-colors" href="#">Analyses</a>
<a class="text-[#44474e] hover:text-[#002046] transition-colors" href="#">Sectors</a>
<a class="text-[#44474e] hover:text-[#002046] transition-colors" href="#">Portfolio</a>
