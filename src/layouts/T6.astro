---
/**
 * Beitrag-Template (T6) — Artikel-Layout.
 * Harmonisiert mit CategoryHub (gleiche Container-Breite, Breadcrumb-Position, H1-Position).
 *
 * Sidebar: Desktop LINKS (lg:order-1), Mobile linear im Fluss.
 * Mobile-Reihenfolge: Hero → TOC → Artikel (mit "Für dich zusammengefasst" als erstem
 * Block) → Beliebte Rechner → Related → Sidebar-CTA.
 *
 * Props:
 *  - title, description, canonical (SEO)
 *  - breadcrumb: { kategorie: string, kategorieHref: string }
 *  - toc: Array<{ id: string, label: string }>
 *  - author, date, readingTime (Meta-Zeile)
 *  - heroAlt, heroSrc (Hero-Bild)
 *  - popularRechner: Array<{ href, title, icon }>
 *  - related: Array<{ href, kategorie, title, teaser, icon }>
 *
 * Content kommt via <slot /> — der gesamte Artikeltext als HTML.
 */
import Base from './Base.astro';
import altTexts from '../data/image-alt-texts.json';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  breadcrumb?: { kategorie: string; kategorieHref: string };
  toc?: Array<{ id: string; label: string }>;
  author?: string;
  date?: string;
  readingTime?: string;
  heroAlt?: string;
  heroSrc?: string;
  popularRechner?: Array<{ href: string; title: string; icon: string }>;
  related?: Array<{ href: string; kategorie: string; title: string; teaser: string; icon: string }>;
  /** FAQ-Daten fuer Schema.org JSON-LD (Question/Answer-Paare) */
  faqItems?: Array<{ question: string; answer: string }>;
  /** ISO-Datum fuer Schema.org datePublished, z.B. "2026-04-15" */
  publishDate?: string;
  /** ISO-Datum fuer Schema.org dateModified */
  updateDate?: string;
}

const {
  title = 'GKV vs. PKV: Die Analyse für Angestellte',
  description,
  canonical,
  breadcrumb = { kategorie: 'Grundlagen', kategorieHref: '/grundlagen/' },
  toc = [
    { id: 'zusammenfassung', label: 'Für dich zusammengefasst' },
    { id: 'systemvergleich', label: 'Systemvergleich im Detail' },
    { id: 'altersrueckstellungen', label: 'Altersrückstellungen' },
    { id: 'vorteile-risiken', label: 'Vorteile & Risiken' },
    { id: 'fazit', label: 'Fazit' },
  ],
  author = 'Tim Bökemeier',
  date = 'Update April 2026',
  readingTime = '12 Min. Lesezeit',
  heroAlt: heroAltProp,
  heroSrc: heroSrcProp,
  popularRechner = [
    { href: '/rechner/pkv-beitrag/', title: 'PKV-Beitragsrechner', icon: 'calculate' },
    { href: '/rechner/pkv-gkv-vergleich/', title: 'GKV vs. PKV Vergleich', icon: 'compare_arrows' },
    { href: '/rechner/arbeitgeberzuschuss/', title: 'Arbeitgeberzuschuss', icon: 'business_center' },
  ],
  related = [
    {
      href: '/grundlagen/lohnt-sich-pkv/',
      kategorie: 'Grundlagen',
      title: 'Lohnt sich die PKV für Angestellte?',
      teaser: 'Datenbasierte Entscheidungshilfe: Wann der Wechsel sich rechnet und wann nicht.',
      icon: 'trending_up',
    },
    {
      href: '/grundlagen/vor-und-nachteile/',
      kategorie: 'Grundlagen',
      title: 'Vor- und Nachteile der PKV',
      teaser: 'Objektive Gegenüberstellung jenseits von Hochglanzprospekten und Verkaufsrhetorik.',
      icon: 'balance',
    },
    {
      href: '/kosten/beitragsanpassung/',
      kategorie: 'Kosten',
      title: 'Beitragsanpassung verstehen',
      teaser: 'Warum Beiträge steigen, nach welchen Regeln und wie du stabile Tarife erkennst.',
      icon: 'trending_up',
    },
  ],
  faqItems,
  publishDate = '2026-04-16',
  updateDate = '2026-04-16',
} = Astro.props;

// Hero-Bild Auto-Erkennung aus URL wenn nicht explizit uebergeben
const urlParts = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const autoHeroId = urlParts.length >= 2 ? `hero-${urlParts[0]}-${urlParts[urlParts.length - 1]}` : '';
const autoHero = autoHeroId ? (altTexts as Record<string, { alt: string; size: string }>)[autoHeroId] : undefined;
const heroSrc = heroSrcProp || (autoHero ? `/img/${autoHeroId}.webp` : '');
const heroAlt = heroAltProp || autoHero?.alt || '';

const hasSlotContent = Astro.slots.has('default');
---
<Base
  title={title + ' | PKV für Angestellte'}
  description={description}
  canonical={canonical}
  schemaType='Article'
  publishDate={publishDate}
  updateDate={updateDate}
  author={author}
  breadcrumbs={[
    { label: 'Start', href: '/' },
    { label: breadcrumb.kategorie, href: breadcrumb.kategorieHref },
    { label: title ?? '', href: '' }
  ]}
  faqItems={faqItems}
>
  <main class='bg-[#FAF7F2]'>
    <!-- Breadcrumbs -->
    <nav class='max-w-6xl mx-auto pt-6 md:pt-10 px-6 md:px-8 flex items-center gap-2 text-xs uppercase tracking-widest text-on-surface-variant' aria-label='Breadcrumb'>
      <a class='hover:text-primary transition-colors' href='/'>Home</a>
      <span class='material-symbols-outlined text-[14px]'>chevron_right</span>
      <a class='hover:text-primary transition-colors' href={breadcrumb.kategorieHref}>{breadcrumb.kategorie}</a>
      <span class='material-symbols-outlined text-[14px]'>chevron_right</span>
      <span class='text-primary font-semibold truncate'>Beitrag</span>
    </nav>

    <div class='max-w-6xl mx-auto px-6 md:px-8 py-8 md:py-12'>
      <!-- HERO: H1 + Meta + kleines Bild -->
      <section class='grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start mb-10 md:mb-14'>
        <div class='lg:col-span-8 min-w-0'>
          <h1 class='font-serif text-primary font-semibold leading-[1.1] break-words text-3xl sm:text-4xl md:text-5xl lg:text-[52px] mb-6'>
            {title}
          </h1>
          <div class='flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-on-surface-variant border-t border-outline-variant/30 pt-4'>
            <div class='flex items-center gap-2'>
              <span class='material-symbols-outlined text-[18px] text-amber-accent-dark'>person</span>
              <span>{author}</span>
            </div>
            <div class='flex items-center gap-2'>
              <span class='material-symbols-outlined text-[18px] text-amber-accent-dark'>update</span>
              <span>{date}</span>
            </div>
            <div class='flex items-center gap-2'>
              <span class='material-symbols-outlined text-[18px] text-amber-accent-dark'>schedule</span>
              <span>{readingTime}</span>
            </div>
          </div>
        </div>
        {heroSrc && (
          <div class='lg:col-span-4 min-w-0'>
            <div class='relative aspect-[4/3] w-full rounded-xl overflow-hidden shadow-lg shadow-primary/10'>
              <img alt={heroAlt} class='w-full h-full object-cover' src={heroSrc} loading='eager' />
            </div>
          </div>
        )}
      </section>

      <!-- Body + Sidebar. Desktop: Sidebar LINKS (order-1), Article rechts (order-2). -->
      <div class='grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16'>
        <!-- DESKTOP-SIDEBAR (nur lg+) -->
        <aside class='hidden lg:block lg:col-span-4 lg:order-1'>
          <div class='lg:sticky lg:top-28 space-y-8'>
            <!-- TOC -->
            <section>
              <p class='text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-4'>Inhalt</p>
              <nav class='flex flex-col toc-root'>
                {toc.map((t) => (
                  <a
                    href={`#${t.id}`}
                    data-toc-id={t.id}
                    class='toc-link block pl-4 py-2 border-l-2 border-outline-variant/30 text-sm text-on-surface-variant hover:text-primary hover:border-amber-accent transition-colors'
                  >{t.label}</a>
                ))}
              </nav>
            </section>

            <!-- Beliebte Rechner -->
            <section>
              <p class='text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-4'>Beliebte Rechner</p>
              <ul class='space-y-2'>
                {popularRechner.map((r) => (
                  <li>
                    <a href={r.href} class='flex items-center gap-3 p-3 bg-white border border-outline-variant/20 rounded-md hover:border-amber-accent/60 hover:shadow-sm transition-all group'>
                      <span class='shrink-0 w-9 h-9 rounded-md bg-gradient-to-br from-[#FAF7F2] to-amber-accent/10 border border-outline-variant/20 flex items-center justify-center'>
                        <span class='material-symbols-outlined text-amber-accent-dark text-[18px]' aria-hidden='true'>{r.icon}</span>
                      </span>
                      <span class='text-sm font-medium text-primary leading-snug group-hover:text-amber-accent-dark transition-colors'>{r.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>

            <!-- Beratung CTA -->
            <section>
              <p class='text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-4'>Beratung</p>
              <button data-contact-trigger class='block w-full text-left bg-primary text-white rounded-xl p-6 hover:brightness-110 transition-all group cursor-pointer'>
                <p class='font-serif text-lg leading-tight mb-2'>Unsicher beim Wechsel?</p>
                <p class='text-primary-fixed-dim text-xs mb-4'>Kostenloses Erstgespräch, unabhängig, ohne Versicherungsbindung.</p>
                <span class='inline-flex items-center gap-1 bg-amber-accent group-hover:bg-amber-accent-dark text-white font-semibold text-sm px-4 py-2 rounded-md transition-all'>
                  Experte kontaktieren
                  <span class='material-symbols-outlined text-[16px]'>support_agent</span>
                </span>
              </button>
            </section>
          </div>
        </aside>

        <!-- MAIN CONTENT -->
        <article class='lg:col-span-8 lg:order-2 min-w-0'>
          <!-- MOBILE-TOC (direkt unter dem Bild) -->
          <section class='lg:hidden mb-12'>
            <p class='font-serif text-2xl text-primary mb-4'>Inhalt</p>
            <nav class='flex flex-col toc-root'>
              {toc.map((t) => (
                <a
                  href={`#${t.id}`}
                  data-toc-id={t.id}
                  class='toc-link block pl-4 py-2 border-l-2 border-outline-variant/30 text-sm text-on-surface-variant hover:text-primary hover:border-amber-accent transition-colors'
                >{t.label}</a>
              ))}
            </nav>
          </section>

          {hasSlotContent ? (
            <slot />
          ) : (
            <!-- FALLBACK: Dummy-Content für Seiten ohne eigenen Inhalt -->
            <Fragment>
              <section id='zusammenfassung' class='scroll-mt-28 mb-12 bg-white border-l-4 border-amber-accent/60 rounded-r-xl p-6 md:p-8 shadow-sm'>
                <h2 class='font-serif text-xl md:text-2xl text-primary mb-4'>Für dich zusammengefasst</h2>
                <ul class='space-y-3 text-on-surface'>
                  <li class='flex items-start gap-3'>
                    <span class='material-symbols-outlined text-amber-accent-dark mt-0.5 shrink-0'>check_circle</span>
                    <span>Wechsel ist ab einem Bruttoeinkommen von 77.400 Euro (2026) möglich.</span>
                  </li>
                  <li class='flex items-start gap-3'>
                    <span class='material-symbols-outlined text-amber-accent-dark mt-0.5 shrink-0'>check_circle</span>
                    <span>Altersrückstellungen sind der wichtigste Hebel gegen Beitragsanstieg im Ruhestand.</span>
                  </li>
                  <li class='flex items-start gap-3'>
                    <span class='material-symbols-outlined text-amber-accent-dark mt-0.5 shrink-0'>check_circle</span>
                    <span>Der Arbeitgeber beteiligt sich an den PKV-Kosten bis zum GKV-Höchstbetrag.</span>
                  </li>
                </ul>
              </section>

              <div class='space-y-5 text-base md:text-[17px] text-on-surface leading-[1.75] mb-12'>
                <p>Die Entscheidung für eine Private Krankenversicherung ist oft weniger eine Kostenfrage, sondern eine Investition in die eigene Leistungsfähigkeit. Während die gesetzliche Krankenversicherung durch das Wirtschaftlichkeitsgebot gebunden ist, bietet die PKV den Zugang zum medizinischen Fortschritt ohne bürokratische Hürden.</p>
                <p>Doch der Wechsel ist keine Einbahnstraße. Wer sich für die PKV entscheidet, wählt ein System, das auf individuellen Risiken und Altersrückstellungen basiert.</p>
              </div>

              <section id='systemvergleich' class='scroll-mt-28 mb-12'>
                <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6'>Systemvergleich im Detail</h2>
                <div class='overflow-x-auto rounded-xl border border-outline-variant/20 bg-white'>
                  <table class='w-full text-left border-collapse min-w-[520px]'>
                    <thead>
                      <tr class='bg-[#FAF7F2]'>
                        <th class='px-5 py-3 font-semibold text-xs uppercase tracking-wider text-on-surface-variant'>Merkmal</th>
                        <th class='px-5 py-3 font-semibold text-xs uppercase tracking-wider text-on-surface-variant'>GKV</th>
                        <th class='px-5 py-3 font-semibold text-xs uppercase tracking-wider text-on-surface-variant'>PKV</th>
                      </tr>
                    </thead>
                    <tbody class='divide-y divide-outline-variant/20'>
                      <tr><td class='px-5 py-4 font-semibold text-primary'>Beitragshöhe</td><td class='px-5 py-4 text-on-surface-variant'>Prozent vom Einkommen</td><td class='px-5 py-4 text-on-surface-variant'>Risiko- & altersabhängig</td></tr>
                      <tr><td class='px-5 py-4 font-semibold text-primary'>Leistungsumfang</td><td class='px-5 py-4 text-on-surface-variant'>Basisversorgung, gesetzlich änderbar</td><td class='px-5 py-4 text-on-surface-variant'>Vertraglich garantiert</td></tr>
                      <tr><td class='px-5 py-4 font-semibold text-primary'>Familie</td><td class='px-5 py-4 text-on-surface-variant'>Beitragsfreie Mitversicherung</td><td class='px-5 py-4 text-on-surface-variant'>Einzelbeitrag pro Person</td></tr>
                      <tr><td class='px-5 py-4 font-semibold text-primary'>Arztwahl</td><td class='px-5 py-4 text-on-surface-variant'>Kassenzulassung nötig</td><td class='px-5 py-4 text-on-surface-variant'>Freie Wahl</td></tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <blockquote class='my-12 py-6 md:py-8 border-y border-outline-variant/30'>
                <p class='font-serif text-xl md:text-2xl italic text-primary leading-snug'>
                  Die PKV ist kein Produkt von der Stange, sondern ein maßgeschneidertes Fundament für die eigene Gesundheitsbiografie.
                </p>
              </blockquote>

              <section id='altersrueckstellungen' class='scroll-mt-28 mb-12'>
                <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6'>Altersrückstellungen</h2>
                <p class='text-base md:text-[17px] text-on-surface leading-[1.75]'>Ein Teil jedes PKV-Beitrags fließt in eine Alterungsrückstellung. Dieser Baustein federt den Beitragsanstieg im Ruhestand ab. Ohne diese Rückstellungen wäre die PKV im hohen Alter für die meisten unbezahlbar.</p>
              </section>

              <section id='vorteile-risiken' class='scroll-mt-28 mb-12'>
                <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6'>Vorteile und Risiken</h2>
                <div class='grid grid-cols-1 md:grid-cols-2 gap-6'>
                  <div class='bg-white border border-outline-variant/20 rounded-lg p-6'>
                    <h3 class='flex items-center gap-2 font-semibold text-primary mb-4'>
                      <span class='material-symbols-outlined text-amber-accent-dark'>add_circle</span>Vorteile
                    </h3>
                    <ul class='space-y-3 text-sm text-on-surface-variant'>
                      <li class='pl-4 border-l-2 border-amber-accent/40'>Kürzere Wartezeiten bei Fachärzten.</li>
                      <li class='pl-4 border-l-2 border-amber-accent/40'>Weltweiter Versicherungsschutz.</li>
                      <li class='pl-4 border-l-2 border-amber-accent/40'>Chefarzt-Behandlung und Einbettzimmer.</li>
                    </ul>
                  </div>
                  <div class='bg-white border border-outline-variant/20 rounded-lg p-6'>
                    <h3 class='flex items-center gap-2 font-semibold text-primary mb-4'>
                      <span class='material-symbols-outlined text-error'>do_not_disturb_on</span>Risiken
                    </h3>
                    <ul class='space-y-3 text-sm text-on-surface-variant'>
                      <li class='pl-4 border-l-2 border-error/30'>Beiträge steigen im Alter ohne Vorsorge.</li>
                      <li class='pl-4 border-l-2 border-error/30'>Rückkehr in die GKV ab 55 Jahren erschwert.</li>
                      <li class='pl-4 border-l-2 border-error/30'>Kinder separat zu versichern.</li>
                    </ul>
                  </div>
                </div>
              </section>

              <section id='fazit' class='scroll-mt-28 mb-12'>
                <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6'>Fazit</h2>
                <p class='text-base md:text-[17px] text-on-surface leading-[1.75]'>Die PKV lohnt sich für Angestellte mit stabilem Einkommen über der JAEG, guter Gesundheit und langfristigem Planungshorizont. Sie lohnt sich nicht als kurzfristiger Sparmove oder für Lebenssituationen mit hoher Unsicherheit. Entscheidend sind nicht der Einstiegsbeitrag, sondern Tarifqualität, Anbieterstabilität und eine saubere Antragsstrecke.</p>
              </section>
            </Fragment>
          )}

          <!-- MOBILE: Beliebte Rechner nach Artikel -->
          <section class='lg:hidden mt-12 mb-12'>
            <p class='font-serif text-2xl text-primary mb-6'>Beliebte Rechner</p>
            <ul class='space-y-2'>
              {popularRechner.map((r) => (
                <li>
                  <a href={r.href} class='flex items-center gap-3 p-3 bg-white border border-outline-variant/20 rounded-md hover:border-amber-accent/60 hover:shadow-sm transition-all group'>
                    <span class='shrink-0 w-9 h-9 rounded-md bg-gradient-to-br from-[#FAF7F2] to-amber-accent/10 border border-outline-variant/20 flex items-center justify-center'>
                      <span class='material-symbols-outlined text-amber-accent-dark text-[18px]' aria-hidden='true'>{r.icon}</span>
                    </span>
                    <span class='text-sm font-medium text-primary leading-snug group-hover:text-amber-accent-dark transition-colors'>{r.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        </article>
      </div>

      <!-- Related — full width -->
      <section class='mt-16 md:mt-20 border-t border-outline-variant/30 pt-12 md:pt-16'>
        <p class='font-serif text-2xl md:text-3xl text-primary mb-6 md:mb-8'>Weitere Beiträge</p>
        <ul class='grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6'>
          {related.map((r) => (
            <li>
              <a href={r.href} class='h-full flex flex-col bg-white border border-outline-variant/20 rounded-lg p-5 hover:border-amber-accent/60 hover:shadow-md hover:shadow-primary/5 transition-all group'>
                <span class='shrink-0 w-11 h-11 rounded-md bg-gradient-to-br from-[#FAF7F2] to-amber-accent/10 border border-outline-variant/20 flex items-center justify-center mb-4'>
                  <span class='material-symbols-outlined text-amber-accent-dark text-[22px]' aria-hidden='true'>{r.icon}</span>
                </span>
                <span class='text-[10px] uppercase tracking-widest font-semibold text-on-surface-variant mb-2'>{r.kategorie}</span>
                <h3 class='font-serif text-lg text-primary leading-snug group-hover:text-amber-accent-dark transition-colors mb-2'>{r.title}</h3>
                <p class='text-sm text-on-surface-variant leading-relaxed'>{r.teaser}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- MOBILE: Sidebar-CTA ganz am Ende -->
      <section class='lg:hidden mt-16'>
        <p class='font-serif text-2xl text-primary mb-6'>Beratung</p>
        <button data-contact-trigger class='block w-full text-left bg-primary text-white rounded-xl p-6 hover:brightness-110 transition-all group cursor-pointer'>
          <p class='font-serif text-lg leading-tight mb-2'>Unsicher beim Wechsel?</p>
          <p class='text-primary-fixed-dim text-xs mb-4'>Kostenloses Erstgespräch, unabhängig, ohne Versicherungsbindung.</p>
          <span class='inline-flex items-center gap-1 bg-amber-accent group-hover:bg-amber-accent-dark text-white font-semibold text-sm px-4 py-2 rounded-md transition-all'>
            Experte kontaktieren
            <span class='material-symbols-outlined text-[16px]'>support_agent</span>
          </span>
        </button>
      </section>
    </div>
  </main>

  <!-- Scrollspy: markiert aktiven TOC-Link in ALLEN .toc-root-Listen (Desktop + Mobile) -->
  <script is:inline>
    (function () {
      const links = Array.from(document.querySelectorAll('.toc-root .toc-link'));
      if (links.length === 0) return;
      const sectionIds = Array.from(new Set(links.map((l) => l.dataset.tocId)));
      const sections = sectionIds.map((id) => document.getElementById(id)).filter(Boolean);
      if (sections.length === 0) return;

      const activate = (id) => {
        links.forEach((l) => {
          const on = l.dataset.tocId === id;
          l.classList.toggle('border-amber-accent', on);
          l.classList.toggle('border-l-4', on);
          l.classList.toggle('border-l-2', !on);
          l.classList.toggle('text-primary', on);
          l.classList.toggle('font-semibold', on);
          l.classList.toggle('bg-amber-accent/5', on);
          l.classList.toggle('text-on-surface-variant', !on);
        });
      };

      const io = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible[0]) activate(visible[0].target.id);
        },
        { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
      );
      sections.forEach((s) => io.observe(s));
      activate(sections[0].id);
    })();
  </script>
</Base>
