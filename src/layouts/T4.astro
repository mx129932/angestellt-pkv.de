---
/**
 * Über-uns-Template (T4).
 * Harmonisiert mit CategoryHub/T2/T5/T6: gleiche Container-Breite (max-w-6xl),
 * gleiche Top-Position (pt-6 md:pt-10), Brand-Tokens durchgezogen,
 * "du"-Ansprache. Fokus: Tim Bökemeier als Experte, PKV-Welt-Team.
 */
import Base from './Base.astro';
import altTexts from '../data/image-alt-texts.json';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const { title = 'Über uns', description, canonical } = Astro.props;

// Hero-Bild fuer Ueber-uns
const heroData = (altTexts as Record<string, { alt: string; size: string }>)['hero-ueber-uns'];
const heroSrc = heroData ? '/img/hero-ueber-uns.webp' : '';
const heroAlt = heroData?.alt || '';

const companyFacts = [
  { label: 'Spezialisierung', value: 'PKV für Angestellte' },
  { label: 'Teil von', value: 'PKV-Welt' },
  { label: 'Team', value: '8 Spezialisten' },
  { label: 'Unabhängigkeit', value: '100 %' },
  { label: 'Provisionen', value: 'Keine' },
];

const team = [
  {
    role: 'PKV-Experte und Autor',
    name: 'Tim Bökemeier',
    text: 'Über 10 Jahre Erfahrung in der privaten Krankenversicherung. Tim analysiert Tarife, Beitragsentwicklungen und Wechselstrategien speziell für Angestellte oberhalb der Versicherungspflichtgrenze.',
    img: '/images/team-tim-color.webp',
  },
  {
    role: 'Kundenmanagement',
    name: 'Sandra',
    text: 'Erste Ansprechpartnerin für alle Kundenanliegen. Sandra koordiniert Beratungstermine und sorgt dafür, dass dein Anliegen schnell beim richtigen Experten landet.',
    img: '/images/team-sandra-color.webp',
  },
  {
    role: 'Tarifoptimierung',
    name: 'Jan',
    text: 'Spezialist für Tarifwechsel nach § 204 VVG und Beitragsoptimierung. Jan findet Einsparpotenziale in bestehenden PKV-Verträgen.',
    img: '/images/team-jan-color.webp',
  },
  {
    role: 'Beamtentarife',
    name: 'Jan',
    text: 'Experte für Beihilfe-konforme Tarife und die Besonderheiten der PKV im öffentlichen Dienst.',
    img: '/images/team-jan-2-color.webp',
  },
  {
    role: 'Unternehmensberatung',
    name: 'Max',
    text: 'Verantwortlich für strategische Entwicklung, digitale Prozesse und die Weiterentwicklung der PKV-Welt-Plattformen.',
    img: '/images/team-max-color.webp',
  },
  {
    role: 'Verwaltung',
    name: 'Frederike',
    text: 'Kümmert sich um die kaufmännische Organisation und hält dem Beratungsteam den Rücken frei.',
    img: '/images/team-frederike-color.webp',
  },
];

const principles = [
  { icon: 'balance', title: 'Unabhängig', text: 'Keine Beteiligungen durch Versicherungskonzerne. Unsere redaktionelle Freiheit ist nicht verhandelbar.' },
  { icon: 'analytics', title: 'Zahlenbasiert', text: 'Jede Aussage stützt sich auf offizielle Quellen: BMG, BMAS, PKV-Verband, GKV-Spitzenverband. Keine Schätzungen.' },
  { icon: 'security', title: 'DSGVO-ernst', text: 'Deine Daten sind kein Handelsgut. Kein aggressives Tracking, keine Datenweitergabe an Dritte.' },
  { icon: 'verified_user', title: 'Kein Verkaufsdruck', text: 'Wir drängen nicht zum Abschluss. Information und Aufklärung stehen im Mittelpunkt, die Entscheidung liegt bei dir.' },
];
---
<Base
  title={title + ' | PKV für Angestellte'}
  description={description}
  canonical={canonical}
  schemaType='AboutPage'
  breadcrumbs={[
    { label: 'Start', href: '/' },
    { label: 'Über uns', href: '' }
  ]}
>
  <main class='bg-[#FAF7F2]'>
    <!-- Breadcrumbs -->
    <nav class='max-w-6xl mx-auto pt-6 md:pt-10 px-6 md:px-8 flex items-center gap-2 text-xs uppercase tracking-widest text-on-surface-variant' aria-label='Breadcrumb'>
      <a class='hover:text-primary transition-colors' href='/'>Home</a>
      <span class='material-symbols-outlined text-[14px]'>chevron_right</span>
      <span class='text-primary font-semibold'>Über uns</span>
    </nav>

    <!-- Hero + Narrative + Company Facts -->
    <section class='max-w-6xl mx-auto px-6 md:px-8 py-8 md:py-12'>
      <header class='mb-10 md:mb-14'>
        <div class={`grid grid-cols-1 ${heroSrc ? 'lg:grid-cols-12' : ''} gap-8 lg:gap-12 items-start`}>
          <div class={heroSrc ? 'lg:col-span-8' : 'max-w-3xl'}>
            <p class='text-xs uppercase tracking-widest text-amber-accent-dark font-bold mb-3'>Über uns</p>
            <h1 class='font-serif text-primary font-semibold leading-[1.1] break-words text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-4'>
              Dein spezialisiertes Informationsportal.
            </h1>
            <p class='text-base md:text-lg text-on-surface-variant leading-relaxed'>
              angestellt-pkv.de ist das Fachportal der PKV-Welt, das sich ausschließlich mit der privaten Krankenversicherung für Angestellte beschäftigt. Keine Selbstständigen, keine Beamten, keine Kompromisse bei der Zielgruppe.
            </p>
          </div>
          {heroSrc && (
            <div class='lg:col-span-4 min-w-0'>
              <div class='relative aspect-[3/2] w-full rounded-xl overflow-hidden shadow-lg shadow-primary/10'>
                <img alt={heroAlt} class='w-full h-full object-cover' src={heroSrc} loading='eager' />
              </div>
            </div>
          )}
        </div>
      </header>

      <div class='grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16'>
        <article class='lg:col-span-8 min-w-0'>
          <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6'>Warum ein eigenes Portal für Angestellte?</h2>
          <div class='space-y-5 text-base md:text-[17px] text-on-surface leading-[1.75] mb-10'>
            <p>
              Als Angestellter oberhalb der Versicherungspflichtgrenze stehst du vor einer Entscheidung, die dich Jahrzehnte begleitet: GKV oder PKV? Die meisten Informationsquellen im Netz mischen Selbstständige, Beamte und Angestellte wild durcheinander. Dabei unterscheiden sich die Rahmenbedingungen fundamental.
            </p>
            <p>
              Der Arbeitgeberzuschuss, die Rückkehrmöglichkeiten in die GKV, die Versicherungspflichtgrenze, der Umgang mit Elternzeit oder Jobwechsel: All das betrifft nur dich als Angestellten. Genau dafür gibt es angestellt-pkv.de.
            </p>
          </div>

          <blockquote class='my-10 py-6 md:py-8 border-y border-outline-variant/30 max-w-2xl'>
            <p class='font-serif text-lg md:text-xl italic text-primary leading-snug'>
              „Ehrliche Beratung bedeutet auch, zu sagen, wenn der Status quo die bessere Lösung ist."
            </p>
            <footer class='mt-4 text-sm text-on-surface-variant'>Tim Bökemeier, PKV-Experte</footer>
          </blockquote>

          <h2 class='font-serif text-2xl md:text-3xl text-primary mb-6'>Was dich hier erwartet</h2>
          <div class='space-y-5 text-base md:text-[17px] text-on-surface leading-[1.75]'>
            <p>
              36 Fachartikel, 10 interaktive Rechner und eine klare Struktur, die dir hilft, die PKV als Angestellter von allen Seiten zu verstehen. Jede Zahl stammt aus offiziellen Quellen (BMG, BMAS, PKV-Verband), jeder Artikel wird von Tim Bökemeier geschrieben und geprüft.
            </p>
            <p>
              Wir verkaufen keine Leads, wir vermitteln keine Verträge. Wir liefern dir die Grundlage, damit du selbst eine informierte Entscheidung treffen kannst.
            </p>
          </div>
        </article>

        <!-- Company Facts Sidebar -->
        <aside class='lg:col-span-4'>
          <div class='lg:sticky lg:top-28 bg-white border border-outline-variant/30 rounded-xl p-6 md:p-8 shadow-sm'>
            <h3 class='text-[10px] font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-6 pb-4 border-b border-outline-variant/30'>Auf einen Blick</h3>
            <dl class='space-y-5'>
              {companyFacts.map((f) => (
                <div>
                  <dt class='text-xs uppercase tracking-widest text-on-surface-variant mb-1'>{f.label}</dt>
                  <dd class='font-serif text-xl text-primary font-semibold'>{f.value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </aside>
      </div>
    </section>

    <!-- Tim Bökemeier — Experte -->
    <section class='bg-white border-y border-outline-variant/30'>
      <div class='max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24'>
        <div class='mb-10 md:mb-14 max-w-3xl'>
          <p class='text-xs uppercase tracking-widest text-amber-accent-dark font-bold mb-3'>Dein Experte</p>
          <h2 class='font-serif text-primary font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl'>
            Tim Bökemeier
          </h2>
        </div>
        <div class='grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start'>
          <div class='lg:col-span-5'>
            <div class='rounded-xl overflow-hidden'>
              <picture>
                <source srcset='/images/tim-experte.webp' type='image/webp' />
                <img alt='Tim Bökemeier, PKV-Experte für Angestellte' class='w-full h-auto object-cover' loading='lazy' src='/images/tim-experte.png' />
              </picture>
            </div>
          </div>
          <div class='lg:col-span-7'>
            <div class='space-y-5 text-base md:text-[17px] text-on-surface leading-[1.75]'>
              <p>
                Tim ist seit über 10 Jahren auf die private Krankenversicherung spezialisiert. Als Autor aller Beiträge auf angestellt-pkv.de verbindet er Praxiserfahrung aus tausenden Beratungsgesprächen mit analytischer Tiefe.
              </p>
              <p>
                Sein Fokus: die Fragen, die Angestellte wirklich beschäftigen. Lohnt sich der Wechsel bei meinem Gehalt? Was passiert bei einem Jobwechsel? Wie entwickeln sich die Beiträge im Alter? Tim rechnet vor, statt zu versprechen.
              </p>
              <p>
                Als Teil der PKV-Welt berät Tim täglich Angestellte, Selbstständige und Beamte. Für angestellt-pkv.de konzentriert er sich auf das, was für dich als Angestellten zählt: Arbeitgeberzuschuss, Versicherungspflichtgrenze, Rückkehroptionen und langfristige Beitragsplanung.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class='max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24'>
      <div class='mb-10 md:mb-14 max-w-3xl'>
        <p class='text-xs uppercase tracking-widest text-amber-accent-dark font-bold mb-3'>Das Team</p>
        <h2 class='font-serif text-primary font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl'>
          Die Köpfe hinter PKV-Welt
        </h2>
      </div>
      <div class='grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 md:gap-8'>
        {team.map((m) => (
          <div class='text-center'>
            <div class='w-24 h-24 md:w-28 md:h-28 mx-auto mb-4 rounded-full overflow-hidden border-2 border-outline-variant/20'>
              <img alt={m.name} class='w-full h-full object-cover' loading='lazy' src={m.img} />
            </div>
            <h3 class='font-semibold text-primary text-sm mb-1'>{m.name}</h3>
            <p class='text-[11px] text-on-surface-variant leading-snug'>{m.role}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Prinzipien -->
    <section class='bg-white border-y border-outline-variant/30'>
      <div class='max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24'>
        <div class='mb-10 md:mb-14 max-w-3xl'>
          <p class='text-xs uppercase tracking-widest text-amber-accent-dark font-bold mb-3'>Prinzipien</p>
          <h2 class='font-serif text-primary font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl'>
            Wofür wir stehen
          </h2>
        </div>
        <div class='grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6'>
          {principles.map((p) => (
            <div class='flex gap-4 bg-[#FAF7F2] border border-outline-variant/30 rounded-xl p-6 md:p-8'>
              <span class='material-symbols-outlined text-amber-accent-dark text-3xl shrink-0'>{p.icon}</span>
              <div>
                <h3 class='font-semibold text-primary mb-2'>{p.title}</h3>
                <p class='text-sm text-on-surface-variant leading-relaxed'>{p.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Base>
