---
/**
 * Conversion-Template (T2) — /beratung/ und /pkv-beratung/.
 * Harmonisiert mit CategoryHub/T5/T6: gleiche Container-Breite, Brand-Tokens,
 * responsive Headline-Pattern, "du"-Ansprache.
 */
import Base from './Base.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /** H1 (kann vom Standard abweichen) */
  headline?: string;
  /** Italic-Zusatz am Ende der H1 */
  headlineAccent?: string;
  /** Lead unter der H1 */
  lead?: string;
  /** Beraternname unter dem Foto */
  advisorName?: string;
  advisorImg?: string;
}

const {
  title = 'Beratung anfragen',
  description,
  canonical,
  headline = 'Lohnt sich die PKV in deiner Situation',
  headlineAccent = 'wirklich?',
  lead = 'Vermeide teure Fehlentscheidungen. Wir erstellen eine unabhängige Analyse deiner persönlichen Kennzahlen: in 30 Minuten, ohne Makler-Gespräch und ohne Verkaufsabsicht.',
  advisorName = 'Tim Bökemeier',
  advisorImg = '/images/tim-avatar.webp',
} = Astro.props;

const keyFacts = [
  { icon: 'verified_user', title: '100% Unabhängig', text: 'Keine Versicherungsbindung. Wir analysieren alle Anbieter neutral.' },
  { icon: 'database', title: 'Datengestützte Analyse', text: 'Über 1,2 Mio. Datenpunkte aus offiziellen Quellen.' },
  { icon: 'groups', title: 'Erfahrene Experten', text: 'Beratung durch spezialisierte Finanzanalysten.' },
];

const process = [
  {
    num: '01',
    title: 'Anfrage & Kurzprofil',
    text: 'Du beschreibst in 5 Minuten deine Situation (Gehalt, Alter, Status, Fragestellung). Keine Registrierung, keine Abschluss-Absicht.',
  },
  {
    num: '02',
    title: 'Datencheck & Analyse',
    text: 'Wir ziehen die relevanten Kennzahlen (JAEG, Beitragsspreizung, Altersrückstellung-Qualität) und gleichen sie mit deinem Profil ab.',
  },
  {
    num: '03',
    title: 'Persönliches Gespräch',
    text: '30 Minuten Video oder Telefon. Wir erklären, was die Zahlen bedeuten, und beantworten deine offenen Fragen. Ohne Verkaufsdruck.',
  },
  {
    num: '04',
    title: 'Schriftliche Analyse',
    text: 'Du bekommst die Ergebnisse als PDF mit Datenquellen, Annahmen und Empfehlung. Du entscheidest allein, ob und wann du aktiv wirst.',
  },
];

const promises = [
  { icon: 'block', title: 'Keine Versicherungsbindung', text: 'Wir sind an keinen Versicherer gebunden und empfehlen ausschließlich nach deinem Profil.' },
  { icon: 'shield_lock', title: 'Keine Datenweitergabe', text: 'Deine Daten bleiben in unserem geschützten System in Deutschland. Keine Lead-Börse.' },
  { icon: 'campaign', title: 'Kein Spam', text: 'Kein Newsletter-Opt-in, keine Werbe-Anrufe, keine Folge-Mails ohne deine Anfrage.' },
  { icon: 'fact_check', title: 'Nachvollziehbare Zahlen', text: 'Jede Empfehlung kommt mit Quelle, Rechenweg und Annahme. Du kannst alles selbst prüfen.' },
  { icon: 'schedule', title: 'Antwort ≤ 24 h', text: 'Werktags melden wir uns innerhalb eines Arbeitstages, meist schneller.' },
  { icon: 'handshake', title: 'Keine Abschlusspflicht', text: 'Die Analyse ist der Output. Ob, wann und mit wem du einen Tarif abschließt, ist deine Entscheidung.' },
];

const testimonials = [
  { initial: 'M', name: 'M., 38', role: 'IT-Projektleiter', quote: 'Hat mir die zwei Fragen beantwortet, die mein Makler nicht wollte. Endlich Klarheit über die Beitragsstabilität im Alter.' },
  { initial: 'S', name: 'S., 42', role: 'Unternehmensberaterin', quote: 'Die Analyse war absolut nüchtern und sachlich. Kein Vergleich zu den bunten Prospekten, die man sonst bekommt.' },
  { initial: 'L', name: 'L., 35', role: 'Senior Developer', quote: 'Für mich als Gutverdiener war die GKV-PKV-Gegenüberstellung Gold wert. Jetzt weiß ich, wo ich stehe.' },
];

const faqs = [
  { q: 'Kostet die Analyse etwas?', a: 'Die Erst-Analyse ist für qualifizierte Angestellte kostenfrei. Wir refinanzieren uns über tiefergehende Beratungsmodule für Unternehmen, nicht über den Verkauf von Versicherungen an Einzelpersonen.' },
  { q: 'Bekomme ich Werbung?', a: 'Nein. Wir hassen Spam genauso wie du. Deine Daten werden ausschließlich für diese spezifische Analyse verwendet. Kein Newsletter-Opt-in ohne deine explizite Anfrage.' },
  { q: 'Werden meine Daten an Versicherer weitergegeben?', a: 'Definitiv nicht. Wir sind keine Lead-Börse. Deine Daten bleiben in unserem geschützten System in Deutschland.' },
  { q: 'Muss ich telefonieren?', a: 'Nur wenn du es ausdrücklich möchtest. Die Basis-Analyse erfolgt schriftlich per E-Mail als PDF-Dokument.' },
  { q: 'Wie unabhängig seid ihr wirklich?', a: 'Wir arbeiten nach dem Honorarberater-Prinzip. Unser Ziel ist Informationstiefe, nicht Abschlussquote. Wir prüfen Tarife aller großen deutschen Anbieter objektiv.' },
];
---
<Base
  title={title + ' | PKV für Angestellte'}
  description={description}
  canonical={canonical}
  schemaType='CollectionPage'
  breadcrumbs={[
    { label: 'Start', href: '/' },
    { label: title ?? 'Beratung', href: '' }
  ]}
>
  <main class='bg-[#FAF7F2]'>
    <!-- Hero — reduziertes Top-Spacing, harmonisiert mit T5/T6 -->
    <section class='max-w-6xl mx-auto px-6 md:px-8 pt-6 md:pt-10 pb-12 md:pb-20'>
      <div class='grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-center'>
        <!-- Left: H1 + Lead + USPs -->
        <div class='lg:col-span-7 space-y-7 order-1'>
          <h1 class='font-serif text-primary font-semibold leading-[1.1] text-4xl sm:text-5xl lg:text-6xl'>
            {headline} <span class='italic'>{headlineAccent}</span>
          </h1>
          <p class='text-base md:text-lg text-on-surface-variant leading-relaxed max-w-xl'>{lead}</p>
          <ul class='space-y-3 pt-1'>
            <li class='flex items-start gap-3'>
              <span class='material-symbols-outlined text-amber-accent-dark shrink-0 mt-0.5'>check_circle</span>
              <span class='font-medium text-primary'>Unabhängige Analyse</span>
            </li>
            <li class='flex items-start gap-3'>
              <span class='material-symbols-outlined text-amber-accent-dark shrink-0 mt-0.5'>check_circle</span>
              <span class='font-medium text-primary'>Echte Zahlen &amp; Fakten</span>
            </li>
            <li class='flex items-start gap-3'>
              <span class='material-symbols-outlined text-amber-accent-dark shrink-0 mt-0.5'>check_circle</span>
              <span class='font-medium text-primary'>Kein Verkaufsdruck</span>
            </li>
          </ul>
          <div class='pt-2'>
            <span class='text-xs uppercase tracking-widest text-on-surface-variant border-l-2 border-outline-variant pl-4 py-1'>
              Keine Versicherungsbindung. Kein Verkauf.
            </span>
          </div>
        </div>

        <!-- Right: Berater-Bild mit Trust-Overlay + CTA -->
        <div class='lg:col-span-5 order-2'>
          <div class='bg-white border border-outline-variant/30 p-6 md:p-8 rounded-xl shadow-sm'>
            <div class='relative overflow-hidden rounded-lg shadow-xl aspect-[4/5]'>
              <img
                alt={advisorName}
                class='w-full h-full object-cover object-top'
                loading='lazy'
                src={advisorImg}
              />
              <!-- Trust-Overlay top: 4.9/5 Bewertung -->
              <div class='absolute top-4 left-4 flex items-center gap-2 bg-white/95 backdrop-blur-sm rounded-full px-3 py-1.5 shadow-md'>
                <span class='material-symbols-outlined text-amber-accent-dark text-[18px]' style='font-variation-settings: "FILL" 1;'>star</span>
                <span class='text-sm font-semibold text-primary'>4,9/5 Bewertung</span>
              </div>
              <!-- Trust-Overlay top: 15+ Jahre Erfahrung -->
              <div class='absolute top-4 right-4 flex items-center gap-2 bg-white/95 backdrop-blur-sm rounded-full px-3 py-1.5 shadow-md'>
                <span class='material-symbols-outlined text-amber-accent-dark text-[18px]'>workspace_premium</span>
                <span class='text-sm font-semibold text-primary'>15+ Jahre</span>
              </div>
              <!-- Berater-Name bottom -->
              <div class='absolute bottom-0 left-0 right-0 bg-gradient-to-t from-primary/90 to-transparent p-5 text-white'>
                <p class='text-[10px] uppercase tracking-[0.2em] font-semibold opacity-80'>Dein Berater</p>
                <p class='font-serif text-xl md:text-2xl'>{advisorName}</p>
              </div>
            </div>
            <div class='mt-5 space-y-2'>
              <a
                class='block w-full text-center py-4 bg-amber-accent hover:bg-amber-accent-dark text-white font-semibold text-base rounded-md shadow-lg shadow-amber-accent/20 transition-all'
                href='#anfrage'
              >
                Anfrage absenden
              </a>
              <p class='text-center text-[10px] uppercase tracking-wider text-on-surface-variant font-medium'>
                Antwort in ≤ 24 Stunden werktags.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Key Facts -->
    <section class='max-w-6xl mx-auto px-6 md:px-8 pb-16 md:pb-20'>
      <div class='grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 border-t border-outline-variant/30 pt-12 md:pt-16'>
        {keyFacts.map((f) => (
          <div class='flex gap-4'>
            <span class='material-symbols-outlined text-amber-accent-dark text-3xl shrink-0'>{f.icon}</span>
            <div>
              <h3 class='font-semibold text-primary mb-2'>{f.title}</h3>
              <p class='text-sm text-on-surface-variant leading-relaxed'>{f.text}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Prozess: So läuft eine Beratung bei uns ab -->
    <section class='bg-white border-y border-outline-variant/30'>
      <div class='max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24'>
        <div class='mb-10 md:mb-14 max-w-3xl'>
          <p class='text-xs uppercase tracking-widest text-amber-accent-dark font-bold mb-3'>Ablauf</p>
          <h2 class='font-serif text-primary font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl mb-4'>
            So läuft eine Beratung bei uns ab
          </h2>
          <p class='text-base md:text-lg text-on-surface-variant leading-relaxed'>
            Vier Schritte, klar strukturiert, ohne Überraschungen. Kein
            Verkaufsgespräch, kein Zeitdruck.
          </p>
        </div>
        <ol class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8'>
          {process.map((p) => (
            <li class='relative bg-[#FAF7F2] border border-outline-variant/30 rounded-xl p-6 md:p-7'>
              <span class='inline-flex items-center justify-center w-10 h-10 rounded-full bg-primary text-white font-serif text-base font-semibold mb-5'>
                {p.num}
              </span>
              <h3 class='font-serif text-xl text-primary font-semibold leading-snug mb-3'>
                {p.title}
              </h3>
              <p class='text-sm text-on-surface-variant leading-relaxed'>{p.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- Unser Versprechen -->
    <section class='max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24'>
      <div class='grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14'>
        <div class='lg:col-span-4'>
          <p class='text-xs uppercase tracking-widest text-amber-accent-dark font-bold mb-3'>Standard</p>
          <h2 class='font-serif text-primary font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl mb-5'>
            Unser Versprechen
          </h2>
          <p class='text-base md:text-lg text-on-surface-variant leading-relaxed'>
            Sechs Zusagen, die du von uns schriftlich bekommst, bevor du uns
            deine Situation schilderst.
          </p>
        </div>
        <div class='lg:col-span-8'>
          <div class='grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6'>
            {promises.map((p) => (
              <div class='flex gap-4 bg-white border border-outline-variant/30 rounded-xl p-5 md:p-6'>
                <span class='material-symbols-outlined text-amber-accent-dark text-2xl shrink-0 mt-0.5'>{p.icon}</span>
                <div>
                  <h3 class='font-semibold text-primary mb-1.5'>{p.title}</h3>
                  <p class='text-sm text-on-surface-variant leading-relaxed'>{p.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonials -->
    <section class='bg-white border-t border-outline-variant/30'>
      <div class='max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24'>
        <div class='mb-10 md:mb-14 max-w-3xl'>
          <h2 class='font-serif text-primary font-semibold leading-tight text-3xl md:text-4xl lg:text-5xl mb-3'>
            Warum Menschen uns ihre Fragen stellen
          </h2>
          <div class='h-1 w-24 bg-amber-accent'></div>
        </div>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8'>
          {testimonials.map((t) => (
            <figure class='bg-[#FAF7F2] border-l-4 border-amber-accent p-6 md:p-8'>
              <div class='flex items-center gap-4 mb-5'>
                <div class='w-12 h-12 bg-primary text-white flex items-center justify-center rounded-full font-serif text-lg'>
                  {t.initial}
                </div>
                <figcaption class='text-sm font-medium text-primary'>{t.name}</figcaption>
              </div>
              <blockquote class='font-serif italic text-lg leading-snug text-primary'>
                „{t.quote}"
              </blockquote>
              <p class='mt-4 text-[10px] font-semibold text-on-surface-variant uppercase tracking-widest'>{t.role}</p>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class='max-w-4xl mx-auto px-6 md:px-8 py-16 md:py-24'>
      <h2 class='font-serif text-primary font-semibold text-3xl md:text-4xl text-center mb-10 md:mb-14'>
        Häufige Fragen zur PKV-Analyse
      </h2>
      <div class='space-y-3'>
        {faqs.map((f, i) => {
          const id = `t2-faq-${i}`;
          return (
            <div class='bg-white border border-outline-variant/30 rounded-lg overflow-hidden'>
              <input type='checkbox' id={id} class='hidden peer' />
              <label
                for={id}
                class='flex justify-between items-center gap-4 cursor-pointer p-5 md:p-6 hover:bg-surface-container-low transition-colors'
              >
                <h3 class='font-serif text-base md:text-lg text-primary pr-4'>{f.q}</h3>
                <span class='material-symbols-outlined text-primary transition-transform duration-200 peer-checked:rotate-45 shrink-0'>add</span>
              </label>
              <div class='grid grid-rows-[0fr] peer-checked:grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-out'>
                <div class='overflow-hidden'>
                  <p class='px-5 md:px-6 pt-1 pb-6 md:pb-7 text-on-surface-variant text-sm md:text-base leading-relaxed'>{f.a}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Final CTA -->
    <section id='anfrage' class='bg-primary text-white py-16 md:py-20 px-6 md:px-8 text-center'>
      <div class='max-w-3xl mx-auto space-y-6'>
        <h2 class='font-serif text-3xl md:text-4xl lg:text-5xl leading-tight'>
          Bereit für eine fundierte Entscheidung?
        </h2>
        <p class='text-white/80 text-base md:text-lg'>
          Analyse bequem per E-Mail. Antwort ≤ 24 Stunden werktags.
        </p>
        <div class='pt-3'>
          <a
            class='inline-flex items-center justify-center gap-2 px-8 md:px-10 py-4 bg-amber-accent hover:bg-amber-accent-dark text-white font-semibold text-base md:text-lg rounded-md transition-all shadow-xl shadow-amber-accent/20'
            href='#'
          >
            Anfrage absenden
            <span class='material-symbols-outlined text-[20px]'>arrow_forward</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Base>
