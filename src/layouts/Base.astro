---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  bodyClass?: string;
}

const {
  title = 'PKV für Angestellte',
  description = 'Unabhängiges Fachportal zur privaten Krankenversicherung für Angestellte',
  canonical,
  bodyClass = 'text-on-background selection:bg-primary-container selection:text-white'
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---
<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Material Symbols aktuell noch remote, Ersatz durch Inline-SVG ist Phase 4 -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
    />
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
