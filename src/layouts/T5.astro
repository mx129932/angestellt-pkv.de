---
/**
 * Rechner-Template (T5).
 * Harmonisiert mit CategoryHub/T6 — gleiche Container-Breite, Breadcrumb-Position,
 * H1-Position. Rechner-Body selbst unverändert (Dummy-Form + Result-Panel).
 * Bei iframeSrc: Rechner-HTML wird per iframe geladen + Auto-Resize + ContactModal-Bridge.
 */
import Base from './Base.astro';
import ContactModal from '../components/ContactModal.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  /** Parent-Crumb, z.B. "Rechner" */
  parentCrumb?: string;
  parentHref?: string;
  /** Kurz-Intro unter H1 */
  intro?: string;
  /**
   * Optional: Pfad zu einer standalone Rechner-HTML in /public/rechner-tools/…
   * Wenn gesetzt, wird das Dummy-Formular durch einen iframe mit Auto-Resize ersetzt.
   * Header, Breadcrumb, Intro, Modul 1 + Modul 2 bleiben unverändert.
   */
  iframeSrc?: string;
  /** Start-Höhe des iframe (px), bis Auto-Resize zuschlägt */
  iframeInitialHeight?: number;
}

const {
  title = 'PKV-Beitragsrechner',
  description,
  canonical,
  parentCrumb = 'Rechner',
  parentHref = '/rechner/',
  intro = 'Schätze in wenigen Sekunden deinen PKV-Beitrag auf Basis von Gehalt, Alter und Tarifprofil. Richtwerte auf Marktdurchschnitt 2026. Kein Versicherer-Angebot, kein Abschluss.',
  iframeSrc,
  iframeInitialHeight = 900,
} = Astro.props;

// Dummy-Teaser für "Weitere Rechner" — wird später aus ia.json befüllt
const relatedCalculators = [
  {
    title: 'Arbeitgeberzuschuss-Rechner',
    description: 'Wie viel dein Arbeitgeber zur PKV zuschießt.',
    href: '/rechner/arbeitgeberzuschuss/',
  },
  {
    title: 'PKV-GKV-Vergleich',
    description: 'Monatliche Netto-Belastung PKV vs. GKV.',
    href: '/rechner/pkv-gkv-vergleich/',
  },
  {
    title: 'JAEG-Check',
    description: 'Liegst du über der Versicherungspflichtgrenze 2026?',
    href: '/rechner/jaeg-check/',
  },
];
---
<Base
  title={title + ' | PKV für Angestellte'}
  description={description}
  canonical={canonical}
  schemaType='WebPage'
  breadcrumbs={[
    { label: 'Start', href: '/' },
    { label: parentCrumb, href: parentHref },
    { label: title ?? 'Rechner', href: '' }
  ]}
  schemaExtra={[{
    "@type": "SoftwareApplication",
    "name": title ?? 'PKV-Rechner',
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    }
  }]}
>
  <main class='bg-[#FAF7F2]'>
    <!-- Breadcrumbs — identisch zu CategoryHub/T6 -->
    <nav class='max-w-6xl mx-auto pt-6 md:pt-10 px-6 md:px-8 flex items-center gap-2 text-xs uppercase tracking-widest text-on-surface-variant' aria-label='Breadcrumb'>
      <a class='hover:text-primary transition-colors' href='/'>Home</a>
      <span class='material-symbols-outlined text-[14px]'>chevron_right</span>
      <a class='hover:text-primary transition-colors' href={parentHref}>{parentCrumb}</a>
      <span class='material-symbols-outlined text-[14px]'>chevron_right</span>
      <span class='text-primary font-semibold truncate'>{title}</span>
    </nav>

    <div class='max-w-6xl mx-auto px-6 md:px-8 py-8 md:py-12'>
      <!-- Header — identisches H1-Pattern wie CategoryHub/T6 -->
      <header class='mb-10 md:mb-14 max-w-3xl'>
        <h1 class='font-serif text-primary font-semibold leading-[1.1] break-words text-3xl sm:text-4xl md:text-5xl lg:text-6xl mb-4'>
          {title}
        </h1>
        {intro && <p class='text-base md:text-lg text-on-surface-variant leading-relaxed'>{intro}</p>}
      </header>

      {iframeSrc ? (
        <div class='rechner-embed'>
          <iframe
            id='rechner-frame'
            src={iframeSrc}
            title={title + ' | interaktiver Rechner'}
            width='100%'
            height={iframeInitialHeight}
            loading='lazy'
            class='w-full border-0 rounded-xl bg-white'
            style={`height:${iframeInitialHeight}px;`}
          ></iframe>
          <script is:inline>
            (function () {
              var f = document.getElementById('rechner-frame');
              if (!f) return;
              function resize() {
                try {
                  var d = f.contentDocument || f.contentWindow.document;
                  if (!d || !d.body) return;
                  var h = Math.max(
                    d.body.scrollHeight,
                    d.documentElement ? d.documentElement.scrollHeight : 0
                  );
                  if (h && h > 100) f.style.height = h + 'px';
                } catch (e) { /* cross-origin — ignore */ }
              }
              f.addEventListener('load', function () {
                resize();
                try {
                  var d = f.contentDocument;
                  if (d && 'MutationObserver' in window) {
                    new MutationObserver(resize).observe(d.body, {
                      subtree: true, childList: true, attributes: true, characterData: true,
                    });
                    d.addEventListener('input', resize, true);
                    d.addEventListener('change', resize, true);
                  }
                } catch (e) {}
                setInterval(resize, 1500);
              });
              window.addEventListener('message', function (ev) {
                if (ev && ev.data && ev.data.type === 'rechner-resize' && ev.data.height) {
                  f.style.height = ev.data.height + 'px';
                }
              });
            })();
          </script>
        </div>
      ) : (
      <Fragment set:html={`
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
  <!-- Form -->
  <section class="lg:col-span-7 space-y-8 min-w-0">
    <div class="bg-white p-6 md:p-8 border border-outline-variant/30 rounded-xl shadow-sm">
      <form class="space-y-8">
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="bg-amber-accent/10 text-amber-accent-dark text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">01</span>
            <label class="font-medium text-base text-primary">Bruttogehalt pro Monat</label>
          </div>
          <div class="relative max-w-md">
            <input class="w-full bg-[#FAF7F2] border-b-2 border-outline-variant focus:border-primary transition-colors py-3 px-4 text-xl font-semibold outline-none appearance-none" type="number" value="5500" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-lg font-bold text-on-surface-variant">€</span>
          </div>
        </div>

        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="bg-amber-accent/10 text-amber-accent-dark text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">02</span>
            <label class="font-medium text-base text-primary">Dein Alter</label>
          </div>
          <div class="max-w-md">
            <input class="w-full bg-[#FAF7F2] border-b-2 border-outline-variant focus:border-primary transition-colors py-3 px-4 text-xl font-semibold outline-none appearance-none" placeholder="z. B. 35" type="number" />
          </div>
        </div>

        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="bg-amber-accent/10 text-amber-accent-dark text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">03</span>
            <label class="font-medium text-base text-primary">Geschlecht</label>
          </div>
          <div class="flex p-1 bg-[#FAF7F2] rounded-lg max-w-md">
            <button class="flex-1 py-2.5 text-sm font-semibold rounded-md bg-white shadow-sm text-primary" type="button">weiblich</button>
            <button class="flex-1 py-2.5 text-sm font-medium text-on-surface-variant hover:text-primary transition-colors" type="button">männlich</button>
            <button class="flex-1 py-2.5 text-sm font-medium text-on-surface-variant hover:text-primary transition-colors" type="button">divers</button>
          </div>
        </div>

        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="bg-amber-accent/10 text-amber-accent-dark text-[10px] font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">04</span>
            <label class="font-medium text-base text-primary">Beruflicher Status</label>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-md">
            <label class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/40 bg-white hover:border-amber-accent/60 transition-colors cursor-pointer">
              <input checked class="w-4 h-4 accent-primary" name="status" type="radio" />
              <span class="text-sm font-medium">Angestellter</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/40 bg-white hover:border-amber-accent/60 transition-colors cursor-pointer">
              <input class="w-4 h-4 accent-primary" name="status" type="radio" />
              <span class="text-sm font-medium">Beamter</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/40 bg-white hover:border-amber-accent/60 transition-colors cursor-pointer">
              <input class="w-4 h-4 accent-primary" name="status" type="radio" />
              <span class="text-sm font-medium">Selbstständig</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-outline-variant/40 bg-white hover:border-amber-accent/60 transition-colors cursor-pointer">
              <input class="w-4 h-4 accent-primary" name="status" type="radio" />
              <span class="text-sm font-medium">Student</span>
            </label>
          </div>
        </div>

        <div class="pt-4 border-t border-outline-variant/20">
          <button class="w-full md:w-auto bg-amber-accent hover:bg-amber-accent-dark text-white font-semibold text-base px-8 py-3.5 rounded-md transition-all shadow-lg shadow-amber-accent/20" type="button">
            Beitrag berechnen
          </button>
          <p class="mt-3 text-xs text-on-surface-variant italic">Richtwerte auf Marktdurchschnitt 2026.</p>
        </div>
      </form>
    </div>
  </section>

  <!-- Result -->
  <aside class="lg:col-span-5 min-w-0 lg:sticky lg:top-28">
    <div class="bg-primary text-white p-6 md:p-8 rounded-xl shadow-xl shadow-primary/10 relative overflow-hidden">
      <div class="absolute -right-10 -bottom-10 w-48 h-48 bg-tertiary-container/20 rounded-full blur-[60px] pointer-events-none"></div>
      <div class="relative z-10 space-y-6">
        <div>
          <p class="text-xs uppercase tracking-widest text-primary-fixed-dim mb-1">Dein geschätzter PKV-Beitrag</p>
          <p class="font-serif text-4xl md:text-5xl font-semibold">€ 643,50<span class="text-base font-body font-normal text-primary-fixed-dim"> / Monat</span></p>
        </div>
        <div class="space-y-2 border-t border-white/10 pt-4 text-sm">
          <div class="flex justify-between"><span class="text-white/70">Dein Anteil</span><span class="font-semibold">€ 643,50</span></div>
          <div class="flex justify-between"><span class="text-white/70">Arbeitgeber</span><span class="font-semibold">€ 344,00</span></div>
          <div class="flex justify-between pt-2 border-t border-white/10 mt-2"><span class="text-white/70">Gesamt</span><span class="font-semibold">€ 987,50</span></div>
        </div>
        <a class="inline-flex items-center gap-2 text-amber-accent font-semibold text-sm hover:gap-3 transition-all" href="#">
          So berechnen wir das <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
        </a>
      </div>
    </div>
  </aside>
</div>
      `} />
      )}

      <!-- Weitere Rechner (3 Teaser) -->
      <section class='mt-16 md:mt-24'>
        <div class='mb-6 md:mb-8 flex items-end justify-between gap-4'>
          <h2 class='font-serif text-2xl md:text-3xl text-primary font-semibold'>
            Weitere Rechner
          </h2>
          <a
            href='/rechner/'
            class='hidden sm:inline-flex items-center gap-1 text-sm font-semibold text-primary hover:text-amber-accent-dark transition-colors whitespace-nowrap'
          >
            Alle Rechner
            <span class='material-symbols-outlined text-[16px]'>arrow_forward</span>
          </a>
        </div>
        <div class='grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6'>
          {relatedCalculators.map((r) => (
            <a
              href={r.href}
              class='group block bg-white border border-outline-variant/30 rounded-xl p-6 hover:border-amber-accent/60 hover:shadow-md transition-all min-h-[140px] flex flex-col'
            >
              <p class='text-[10px] uppercase tracking-widest text-amber-accent-dark font-bold mb-3'>Rechner</p>
              <h3 class='font-serif text-lg md:text-xl text-primary font-semibold leading-snug mb-2 group-hover:text-amber-accent-dark transition-colors'>
                {r.title}
              </h3>
              <p class='text-sm text-on-surface-variant leading-relaxed flex-1'>
                {r.description}
              </p>
              <span class='mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary group-hover:gap-2 transition-all'>
                Zum Rechner
                <span class='material-symbols-outlined text-[16px]'>arrow_forward</span>
              </span>
            </a>
          ))}
        </div>
      </section>
    </div>
  </main>

  <ContactModal />
</Base>
