---
import T6 from '../../../layouts/T6.astro';

const toc = [
  { id: 'zusammenfassung', label: 'Für dich zusammengefasst' },
  { id: 'was', label: 'Was die betriebliche Krankenversicherung ist' },
  { id: 'vorteile', label: 'Vorteile fuer Arbeitnehmer' },
  { id: 'sachbezug', label: 'Sachbezugsgrenze und Steuereffekt' },
  { id: 'leistungen', label: 'Typische Leistungen' },
  { id: 'doppel', label: 'BKV und PKV: Doppelerstattung?' },
  { id: 'fazit', label: 'Fazit' },
  { id: 'faq', label: 'Häufige Fragen' },
];

const related = [
  {
    href: '/grundlagen/gkv-vs-pkv/',
    kategorie: 'Grundlagen',
    title: 'GKV vs. PKV Vergleich',
    teaser: 'Systemvergleich mit allen Unterschieden.',
    icon: 'trending_up',
  },
  {
    href: '/leistungen/übersicht/',
    kategorie: 'Leistungen',
