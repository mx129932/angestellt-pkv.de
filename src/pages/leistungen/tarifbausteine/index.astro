  { id: 'ambulant', label: 'Ambulanter Baustein: Was er enthält' },
  { id: 'stationär', label: 'Stationärer Baustein: Einbett bis Mehrbett' },
  { id: 'zahn', label: 'Zahnbaustein: Wo die größten Unterschiede liegen' },
  { id: 'pflege', label: 'Pflege und Zusatzbausteine' },
  { id: 'fazit', label: 'Fazit: Worauf du nicht verzichten solltest' },
  { id: 'faq', label: 'Häufige Fragen' },
];

const related = [
  {
    href: '/leistungen/uebersicht/',
    kategorie: 'Leistungen',
    title: 'PKV-Leistungen im Überblick',
    teaser: 'Welche Leistungen die PKV bietet und worin sie von der GKV unterscheidet.',
    icon: 'health_and_safety',
  },
  {
    href: '/leistungen/beste-pkv/',
    kategorie: 'Leistungen',
    title: 'Beste PKV-Tarife für Angestellte',
    teaser: 'Welche Tarife in Tests gut abschneiden und worauf du bei der Auswahl achtest.',
    icon: 'grade',
  },
  {
    href: '/kosten/selbstbeteiligung/',
    kategorie: 'Kosten',
    title: 'Selbstbeteiligung in der PKV',
