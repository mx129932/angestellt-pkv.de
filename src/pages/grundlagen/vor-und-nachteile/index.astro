  { id: 'vorteile', label: 'Die Vorteile der PKV für Angestellte' },
  { id: 'nachteile', label: 'Die Nachteile der PKV für Angestellte' },
  { id: 'nachteile-schwer', label: 'Welche Nachteile wiegen am schwersten' },
  { id: 'strukturelle-gkv', label: 'Strukturelle GKV-Risiken im Vergleich' },
  { id: 'fazit', label: 'Fazit: Für wen überwiegen die Vorteile' },
  { id: 'faq', label: 'Häufige Fragen' },
];

const related = [
  {
    href: '/grundlagen/lohnt-sich-pkv/',
    kategorie: 'Grundlagen',
    title: 'Lohnt sich die PKV für Angestellte?',
    teaser: 'Datenbasierte Entscheidungshilfe mit konkreten Rechenbeispielen für verschiedene Lebenssituationen.',
    icon: 'trending_up',
  },
  {
    href: '/kosten/beitragsanpassung/',
    kategorie: 'Kosten',
    title: 'Beitragsanpassung PKV: Mechanismus und Risiken',
    teaser: 'Wie PKV-Beiträge angepasst werden, Prognosen für die Zukunft und was du tun kannst.',
    icon: 'payments',
  },
  {
    href: '/kosten/pkv-im-alter/',
    kategorie: 'Kosten',
    title: 'PKV im Alter: Altersrückstellungen und Rentner-Realität',
