---
import T6 from '../../../layouts/T6.astro';

const toc = [
  { id: 'zusammenfassung', label: 'Für dich zusammengefasst' },
  { id: 'bedeutung', label: 'Was ein Leistungsausschluss bedeutet' },
  { id: 'typische-ausschluesse', label: 'Typische Ausschlüsse in der PKV' },
  { id: 'ausschluss-vs-zuschlag', label: 'Ausschluss vs. Risikozuschlag: Abwägung' },
  { id: 'formulierung', label: 'Formulierung entscheidet über Tragweite' },
  { id: 'fazit', label: 'Fazit' },
  { id: 'faq', label: 'Häufige Fragen' },
];

const related = [
  {
    href: '/aufnahme/risikozuschlag/',
    kategorie: 'Aufnahme',
    title: 'PKV-Risikozuschlag: Ursachen, Höhe, Strategien',
    teaser: 'Ein PKV-Risikozuschlag von 5 bis 50 Prozent kann bei Vorerkrankungen drohen.',
    icon: 'trending_up',
  },
  {
    href: '/aufnahme/wartezeiten/',
    kategorie: 'Aufnahme',
    title: 'Wartezeiten in der PKV',
    teaser: 'Ab wann leistet die PKV? Allgemeine und besondere Wartezeiten im Überblick.',
    icon: 'schedule',
  },
  {
