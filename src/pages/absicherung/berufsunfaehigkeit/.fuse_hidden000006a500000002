---
import T6 from '../../../layouts/T6.astro';

const toc = [
  { id: 'zusammenfassung', label: 'Für dich zusammengefasst' },
  { id: 'zeitlich', label: 'Zeitliche Abfolge: Lohnfortzahlung, KTG, BU' },
  { id: 'versorgungsluecke', label: 'Die Versorgungsluecke als PKV-Versicherter' },
  { id: 'hu_rente', label: 'BU-Rente: Wie hoch sollte sie sein' },
  { id: 'beitragsbefreiung', label: 'Beitragsbefreiung als PKV-Zusatzbaustein' },
  { id: 'fazit', label: 'Fazit' },
  { id: 'faq', label: 'Häufige Fragen' },
];

const related = [
  {
    href: '/absicherung/krankentagegeld/',
    kategorie: 'Absicherung',
    title: 'Krankentagegeld in der PKV',
    teaser: 'Krankentagegeld sichert dein Einkommen ab dem 43. Tag Krankheit ab.',
    icon: 'shield',
  },
  {
    href: '/kosten/pkv-kosten-übersicht/',
    kategorie: 'Kosten',
    title: 'PKV-Kosten Übersicht',
    teaser: 'Alle Kostenkomponenten der privaten Krankenversicherung im Überblick.',
    icon: 'payments',
  },
  {
    href: '/leistungen/tarifbausteine/',
    kategorie: 'Leistungen',
