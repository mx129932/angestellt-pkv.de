];

const related = [
  {
    href: '/wechsel/gkv-in-pkv/',
    kategorie: 'Wechsel',
    title: 'Von der GKV in die PKV wechseln',
    teaser: 'Der komplette Ablauf: Voraussetzungen, Fristen und Sonderfälle erklärt.',
    icon: 'swap_horiz',
  },
  {
    href: '/grundlagen/gkv-vs-pkv/',
    kategorie: 'Grundlagen',
