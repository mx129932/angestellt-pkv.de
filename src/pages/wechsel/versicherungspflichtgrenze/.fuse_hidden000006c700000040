  { id: 'überblick', label: 'Die Versicherungspflichtgrenze 2026 im Überblick' },
  { id: 'was_zählt', label: 'Was zum Jahresarbeitsentgelt zählt' },
  { id: 'besondere', label: 'Allgemeine vs. besondere JAEG' },
  { id: 'wann_wechsel', label: 'Wann der Wechsel in die PKV möglich wird' },
  { id: 'rueckfall', label: 'Was passiert bei Gehaltsrückfall' },
  { id: 'fazit', label: 'Fazit' },
